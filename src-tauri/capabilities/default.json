{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Capability for the main window",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "opener:default"
  ],
  "remote": {
    "urls": [
      "https://mail.google.com/**",
      "https://outlook.live.com/**",
      "https://www.icloud.com/**",
      "https://*.google.com/**",
      "https://*.live.com/**",
      "https://*.icloud.com/**"
    ]
  }
}
